{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "app/**",
      "netlify/functions/**",
      "reports/**",
      "scripts/**",
      "tests/**",
      "*.css",
      "*.html",
      "*.js",
      "*.json",
      "*.ts",
      "!package-lock.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineEnding": "crlf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noSvgWithoutTitle": "off",
        "useAltText": "off",
        "useButtonType": "off",
        "useHtmlLang": "off"
      },
      "complexity": {
        "useOptionalChain": "off"
      },
      "correctness": {
        "noInnerDeclarations": "off",
        "noUnusedFunctionParameters": "off",
        "noUnusedVariables": "off"
      },
      "style": {
        "useNodejsImportProtocol": "off",
        "useTemplate": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off",
        "noControlCharactersInRegex": "off",
        "noDuplicateObjectKeys": "off",
        "noGlobalIsNan": "off",
        "noRedundantUseStrict": "off",
        "useIterableCallbackReturn": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
